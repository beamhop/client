{
  "name": "verity-nostr",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test:unit": "bun run --filter '@beamhop/core' test && bun run --filter '@beamhop/web' test:unit",
    "test:e2e": "bun run --filter '@beamhop/web' test:e2e",
    "dev": "bun run --filter '@beamhop/web' dev",
    "build": "bun run --filter '@beamhop/core' build && bun run --filter '@beamhop/web' build",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "typescript": "^5.7.3"
  }
}
